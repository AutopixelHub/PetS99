-- ══════════════════════════════════════════
local leverPulled = { Boss1 = false, Boss2 = false, Boss3 = false }

local function clickHitbox(hitbox, double)
    local hrp = getHRP()
    if not hrp then return end
    hrp.CFrame = CFrame.new(hitbox.Position + Vector3.new(0, 3, 0))
    task.wait(0.5)
    local screenPos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(hitbox.Position)
    if onScreen then
        clickAt(screenPos.X, screenPos.Y)
        if double then
            task.wait(0.5)
            clickAt(screenPos.X, screenPos.Y)
        end
    end
end

local function openDoor(doorModel)
    local hrp = getHRP()
    if not hrp then return end
    local doorPart = doorModel:FindFirstChildWhichIsA("BasePart", true)
    if not doorPart then return end
    hrp.CFrame = CFrame.new(doorPart.Position + Vector3.new(0, 3, 0))
    task.wait(0.5)
    pressE()
    task.wait(1)
end

local function pullLever(bossName, mythicKey)
    if not state.BossLevers then return end
    local ok, hitbox = pcall(function()
        return workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyRaid.Rooms[bossName].Lever.Hitbox
    end)
    if not ok or not hitbox then return end
    setStatus("Pulling " .. bossName .. " lever!", true)
    clickHitbox(hitbox, mythicKey and state[mythicKey])
    task.wait(1.5)
    local okDoor, door = pcall(function()
        return workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyRaid.Rooms[bossName].Door
    end)
    if not okDoor or not door then return end
    setStatus("Opening " .. bossName .. " door!", true)
    openDoor(door)
end

local function getPlayerRoom()
    local hrp = getHRP()
    if not hrp then return nil end
    local ok, rooms = pcall(function()
        return workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyRaid.Rooms
    end)
    if not ok or not rooms then return nil end
    for i = 1, 10 do
        local room = rooms:FindFirstChild("Room" .. i)
        if room then
            local center = room:FindFirstChild("Center")
            if center and (hrp.Position - center.Position).Magnitude < 100 then
                return i
            end
        end
    end
    return nil
end

local function checkBossLevers(currentRoom)
    if not state.BossLevers then return end
    if currentRoom == 3 and not leverPulled.Boss1 then
        pullLever("Boss1", "MythicBoss1")
        leverPulled.Boss1 = true
    elseif currentRoom == 9 and not leverPulled.Boss2 then
        pullLever("Boss2", "MythicBoss2")
        leverPulled.Boss2 = true
    end
end

local function pullHardLever()
    if not state.HardLever then return end
    if leverPulled.Boss3 then return end
    local ok, hitbox = pcall(function()
        return workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyRaid.Rooms.Boss3.Lever.Hitbox
    end)
    if not ok or not hitbox then return end
    setStatus("Pulling Boss3 lever!", true)
    clickHitbox(hitbox, state.MythicBoss3)
    task.wait(1)
    leverPulled.Boss3 = true

    -- Only open the door if HardRoom is also enabled
    if not state.HardRoom then return end

    local okDoor, door = pcall(function()
        return workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyRaid.Rooms.Boss3.Door
    end)
    if not okDoor or not door then return end
    setStatus("Opening Boss3 door!", true)
    local hrp = getHRP()
    if not hrp then return end
    local doorPart = door:FindFirstChildWhichIsA("BasePart", true)
    if not doorPart then return end
    hrp.CFrame = CFrame.new(doorPart.Position + Vector3.new(0, 3, 0))
    task.wait(0.5)
    pressE()
    task.wait(1.5)
    -- Confirm hard room dialog
    setStatus("Confirming hard room...", true)
    clickButton("Confirm")
    task.wait(0.5)
end

-- ══════════════════════════════════════════
--         CHESTS
-- ══════════════════════════════════════════
local function openChest(chest)
    local hrp = getHRP()
    if not hrp then return end
    local bottom = chest:FindFirstChild("Bottom")
    if not bottom then return end
    setStatus("Opening " .. chest.Name, true)
    hrp.CFrame = CFrame.new(bottom.Position + Vector3.new(0, 3, 0))
    task.wait(0.5)
    pressE()
    task.wait(1)
end

local function lootChests()
    local ok, interact = pcall(function()
        return workspace.__THINGS.__INSTANCE_CONTAINER.Active.LuckyRaid.INTERACT
    end)
    if not ok or not interact then return end
    for _, name in ipairs({"HugeChest", "Tier1000Chest", "TitanicChest", "LootChest"}) do
        local chest = interact:FindFirstChild(name)
        if chest then openChest(chest) end
    end
    if state.LeprechaunChest then
        local lep = interact:FindFirstChild("LeprechaunChest")
        if lep then
            local bottom = lep:FindFirstChild("Bottom")
            if bottom then
                local hrp = getHRP()
                if hrp then
                    setStatus("Leprechaun Chest", true)
                    hrp.CFrame = CFrame.new(bottom.Position + Vector3.new(0, 3, 0))
                    task.wait(0.5)
                    pressE()
                    task.wait(1.5)
                    clickButton("Confirm")
                    task.wait(0.5)
                end
            end
        end
    end
    setStatus("Chests done!", true)
end

local function waitForTeleport()
    local hrp = getHRP()
    if not hrp then return end
    local startPos = hrp.Position
    setAutoRaid(true)
    setStatus("Waiting for teleport...", true)
    local elapsed = 0
    while running do
        task.wait(0.2)
        elapsed += 0.2
        if (hrp.Position - startPos).Magnitude > 50 then
            setStatus("Loading screen, waiting...", true)
            task.wait(5)
            setAutoRaid(false)
            leverPulled.Boss1 = false
            leverPulled.Boss2 = false
            leverPulled.Boss3 = false
            setStatus("Idle", false)
            return
        end
        -- Retry click every 20s in case it didn't register
        if elapsed >= 20 then
            elapsed = 0
            setStatus("Retrying teleport...", true)
            clickButton("AutoRaid")
        end
    end
end

-- ══════════════════════════════════════════
--         MAIN LOOP  (v1 logic, untouched)
-- ══════════════════════════════════════════
print("=== Lucky Raid Hub Loaded === (F4 to toggle)")

local chestsDone = false

while running do
    task.wait(0.5)

    local hrp = getHRP()
    if not hrp then task.wait(1) continue end

    if hasBreakables() then
        chestsDone = false
        local currentRoom = getPlayerRoom()
        if currentRoom then checkBossLevers(currentRoom) end
        if state.AutoTeleport then
            setStatus("Teleporting...", true)
            teleportToBreakable()
        else
            setStatus("Idle", false)
        end
    else
        leverPulled.Boss1 = false
        leverPulled.Boss2 = false
        if state.AutoChests and not chestsDone then
            if state.HardLever and not leverPulled.Boss3 then
                pullHardLever()
                -- If HardRoom is on, new breakables will spawn — wait for them
                -- then let the main loop handle the farming pass before chests
                if state.HardRoom then
                    setStatus("Waiting for hard room breakables...", true)
                    local waited = 0
                    while running and waited < 10 do
                        task.wait(0.5)
                        waited += 0.5
                        if hasBreakables() then break end
                    end
                    continue -- go back to top; breakables branch will handle farming
                end
            end
            setStatus("Looting chests...", true)
            lootChests()
            chestsDone = true
            if state.AutoRaidRestart then
                waitForTeleport()
            else
                setStatus("Done!", false)
            end
        else
            setStatus("Idle", false)
        end
    end
end

