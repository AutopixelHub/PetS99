local function makeToggle(parent, label, desc, key, order)
    local t = T()
    local color = TOGGLE_COLORS[key]
    local icon  = TOGGLE_ICONS[key]

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 62)
    row.BackgroundColor3 = t.card
    row.BackgroundTransparency = 1
    row.BorderSizePixel = 0
    row.LayoutOrder = order
    row.Parent = parent
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 14)

    task.delay(order * 0.06, function()
        TweenService:Create(row, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0,
        }):Play()
    end)

    local iconBox = Instance.new("Frame")
    iconBox.Size = UDim2.new(0, 38, 0, 38)
    iconBox.Position = UDim2.new(0, 10, 0.5, -19)
    iconBox.BackgroundColor3 = color
    iconBox.BackgroundTransparency = 0.15
    iconBox.BorderSizePixel = 0
    iconBox.Parent = row
    Instance.new("UICorner", iconBox).CornerRadius = UDim.new(0, 11)

    local iconTxt = Instance.new("TextLabel")
    iconTxt.Size = UDim2.new(1, 0, 1, 0)
    iconTxt.BackgroundTransparency = 1
    iconTxt.Text = icon
    iconTxt.TextSize = 18
    iconTxt.Font = Enum.Font.GothamBold
    iconTxt.Parent = iconBox

    local labelTxt = Instance.new("TextLabel")
    labelTxt.Size = UDim2.new(1, -110, 0, 22)
    labelTxt.Position = UDim2.new(0, 56, 0, 9)
    labelTxt.BackgroundTransparency = 1
    labelTxt.Text = label
    labelTxt.TextColor3 = t.text
    labelTxt.TextSize = 12
    labelTxt.Font = Enum.Font.GothamBold
    labelTxt.TextXAlignment = Enum.TextXAlignment.Left
    labelTxt.Parent = row

    local descTxt = Instance.new("TextLabel")
    descTxt.Size = UDim2.new(1, -110, 0, 14)
    descTxt.Position = UDim2.new(0, 56, 0, 33)
    descTxt.BackgroundTransparency = 1
    descTxt.Text = desc
    descTxt.TextColor3 = t.muted
    descTxt.TextSize = 9
    descTxt.Font = Enum.Font.Gotham
    descTxt.TextXAlignment = Enum.TextXAlignment.Left
    descTxt.Parent = row

    local pillBg = Instance.new("Frame")
    pillBg.Size = UDim2.new(0, 44, 0, 24)
    pillBg.Position = UDim2.new(1, -52, 0.5, -12)
    pillBg.BackgroundColor3 = t.pillOff
    pillBg.BorderSizePixel = 0
    pillBg.Parent = row
    Instance.new("UICorner", pillBg).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0, 3, 0.5, -9)
    knob.BackgroundColor3 = t.knobOff
    knob.BorderSizePixel = 0
    knob.Parent = pillBg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = row

    btn.MouseEnter:Connect(function()
        TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3 = T().card:Lerp(color, 0.08)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3 = T().card}):Play()
    end)

    local function update()
        local on = state[key]
        local ct = T()
        TweenService:Create(pillBg, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
            BackgroundColor3 = on and color or ct.pillOff
        }):Play()
        TweenService:Create(knob, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
            Position = on and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
            BackgroundColor3 = on and Color3.fromRGB(255,255,255) or ct.knobOff
        }):Play()
        TweenService:Create(iconBox, TweenInfo.new(0.2), {
            BackgroundTransparency = on and 0 or 0.15
        }):Play()
    end

    btn.MouseButton1Click:Connect(function()
        state[key] = not state[key]
        update()
    end)

    table.insert(themeElements, {
        row = row, label = labelTxt, desc = descTxt,
        pillBg = pillBg, knob = knob, key = key, update = update,
    })
end

