-- ══════════════════════════════════════════
local PROFILES_FILE = "LuckyRaidHub_profiles.json"

local function loadAllProfiles()
    local ok, raw = pcall(readfile, PROFILES_FILE)
    if not ok or not raw then return {} end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
    return (ok2 and data) and data or {}
end

local function saveAllProfiles(profiles)
    pcall(function()
        writefile(PROFILES_FILE, HttpService:JSONEncode(profiles))
    end)
end

local function saveProfile(name)
    local profiles = loadAllProfiles()
    profiles[name] = {state = state, buttonPos = buttonPos, isDark = isDark}
    saveAllProfiles(profiles)
end

local function applyProfile(data)
    if data.state then
        for k, v in pairs(data.state) do
            if state[k] ~= nil then state[k] = v end
        end
    end
    if data.buttonPos then
        for k, v in pairs(data.buttonPos) do
            if buttonPos[k] then buttonPos[k] = v end
        end
    end
    if data.isDark ~= nil then isDark = data.isDark end
end

local function deleteProfile(name)
    local profiles = loadAllProfiles()
    profiles[name] = nil
    saveAllProfiles(profiles)
end

