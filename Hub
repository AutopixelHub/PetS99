    for _, v in ipairs(workspace.__THINGS.Breakables:GetChildren()) do
        if tonumber(v.Name) then
            local part = v:FindFirstChildWhichIsA("BasePart", true)
            if part then
                hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 5, 0))
