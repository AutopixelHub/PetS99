    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -16, 0, 20)
    lbl.Position = UDim2.new(0, 12, 0, 8)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = DARK.text
    lbl.TextSize = 12
    lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = card

    local coords = Instance.new("TextLabel")
    coords.Size = UDim2.new(1, -16, 0, 14)
    coords.Position = UDim2.new(0, 12, 0, 30)
    coords.BackgroundTransparency = 1
    coords.Text = "x: " .. buttonPos[key].x .. "  y: " .. buttonPos[key].y
    coords.TextColor3 = DARK.muted
    coords.TextSize = 10
    coords.Font = Enum.Font.Gotham
    coords.TextXAlignment = Enum.TextXAlignment.Left
    coords.Parent = card

    local setBtn = Instance.new("TextButton")
    setBtn.Size = UDim2.new(1, -24, 0, 26)
    setBtn.Position = UDim2.new(0, 12, 1, -34)
    setBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 200)
    setBtn.BorderSizePixel = 0
    setBtn.Text = "📍  Set Position"
    setBtn.TextColor3 = Color3.fromRGB(255,255,255)
    setBtn.TextSize = 11
    setBtn.Font = Enum.Font.GothamBold
    setBtn.Parent = card
    Instance.new("UICorner", setBtn).CornerRadius = UDim.new(0, 9)

    setBtn.MouseButton1Click:Connect(function()
        if pickingMode then return end
        pickingMode = key
        setBtn.BackgroundColor3 = Color3.fromRGB(255, 140, 0)
        setStatus("Hover over " .. label .. " and click!", true)

        local moveConn, clickConn

        moveConn = RunService.RenderStepped:Connect(function()
            if pickingMode ~= key then moveConn:Disconnect() return end
            local mp = UserInputService:GetMouseLocation()
            setBtn.Text = "🖱️  x: " .. math.floor(mp.X) .. "  y: " .. math.floor(mp.Y)
        end)

        task.delay(0.2, function()
            clickConn = UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local mp = UserInputService:GetMouseLocation()
                    buttonPos[key] = {x = math.floor(mp.X), y = math.floor(mp.Y)}
                    coords.Text = "x: " .. buttonPos[key].x .. "  y: " .. buttonPos[key].y
                    setBtn.Text = "✅  Saved successfully!"
                    setBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 90)
                    pickingMode = nil
                    setStatus("Position saved! ✓", true)
                    moveConn:Disconnect()
                    clickConn:Disconnect()
                    task.delay(2, function()
                        if setBtn and setBtn.Parent then
                            setBtn.Text = "📍  Set Position"
                            setBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 200)
                        end
                    end)
                end
            end)
        end)
    end)

    table.insert(themeElements, {
        row = card, label = lbl, desc = coords,
        pillBg = card, knob = card, key = "__nokey__",
        update = function() end,
    })
end

