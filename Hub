local function selectTab(name)
    activeTab = name
    for tabName, data in pairs(tabs) do
        local isActive = tabName == name
        TweenService:Create(data.btn, TweenInfo.new(0.2), {
            BackgroundColor3 = isActive and Color3.fromRGB(80, 40, 200) or T().tab,
            TextColor3 = isActive and Color3.fromRGB(255,255,255) or T().sub,
        }):Play()
        tabPages[tabName].Visible = isActive
    end
end

local function makeTab(name, icon, page, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.25, -3, 1, -8)
    btn.BackgroundColor3 = DARK.tab
    btn.BorderSizePixel = 0
    btn.Text = icon .. " " .. name
    btn.TextColor3 = DARK.sub
    btn.TextSize = 10
    btn.Font = Enum.Font.GothamBold
    btn.LayoutOrder = order
    btn.Parent = tabBar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 9)
    tabs[name] = {btn = btn}
    tabPages[name] = page
    btn.MouseButton1Click:Connect(function() selectTab(name) end)
end

