local winVisible = true

local function showWindow()
    if winVisible then return end
    winVisible = true
    win.Visible = true
    miniPill.Visible = false
    win.Size = UDim2.new(0, 0, 0, 0)
    win.Position = UDim2.new(0, 20, 0.5, 0)
    TweenService:Create(win, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, WIN_W, 0, WIN_H),
        Position = UDim2.new(0, 20, 0.5, -WIN_H/2),
    }):Play()
end

local function hideWindow()
    if not winVisible then return end
    winVisible = false
    TweenService:Create(win, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0, 20, 0.5, 0),
    }):Play()
    task.delay(0.3, function()
        win.Visible = false
        miniPill.Size = UDim2.new(0, 0, 0, 42)
        miniPill.Visible = true
        TweenService:Create(miniPill, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 160, 0, 42),
        }):Play()
    end)
end

