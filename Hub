local themeElements = {}

local function applyTheme()
    local t = T()
    TweenService:Create(win, TweenInfo.new(0.3), {BackgroundColor3 = t.bg}):Play()
    TweenService:Create(statusBar, TweenInfo.new(0.3), {BackgroundColor3 = t.status}):Play()
    TweenService:Create(tabBar, TweenInfo.new(0.3), {BackgroundColor3 = t.tab}):Play()
    statusTxt.TextColor3 = t.sub
    themeBtn.Text = isDark and "🌙" or "☀️"
    for tabName, data in pairs(tabs) do
        local isActive = tabName == activeTab
        TweenService:Create(data.btn, TweenInfo.new(0.2), {
            BackgroundColor3 = isActive and t.tabSel or t.tab,
            TextColor3 = isActive and Color3.fromRGB(255,255,255) or t.sub,
        }):Play()
    end
    for _, el in ipairs(themeElements) do
        if el.key ~= "__nokey__" then
            TweenService:Create(el.row, TweenInfo.new(0.3), {BackgroundColor3 = t.card}):Play()
            el.label.TextColor3 = t.text
            el.desc.TextColor3 = t.muted
            if not state[el.key] then
                TweenService:Create(el.pillBg, TweenInfo.new(0.3), {BackgroundColor3 = t.pillOff}):Play()
                TweenService:Create(el.knob, TweenInfo.new(0.3), {BackgroundColor3 = t.knobOff}):Play()
            end
        end
    end
end

